# Backend
SECRET_KEY=change-me-to-a-random-32-char-string
DATABASE_URL=sqlite+aiosqlite:///./data/knowledge.db

# ── Embedding provider ────────────────────────────────────────────────────────
# Default: local sentence-transformers (all-MiniLM-L6-v2, fully offline, dim=384)
# Upgrade:  set EMBEDDING_PROVIDER=openai and provide OPENAI_API_KEY below
EMBEDDING_PROVIDER=local
LOCAL_EMBED_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIM=384

# ── LLM provider ──────────────────────────────────────────────────────────────
# Default: Ollama running locally (install from https://ollama.com)
#   ollama pull llama3.1:8b
# Upgrade:  set LLM_PROVIDER=openai and provide OPENAI_API_KEY below
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# ── OpenAI (optional upgrade — leave blank for fully offline operation) ────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBED_MODEL=text-embedding-3-small

# ── Offline mode for local embedding model ───────────────────────────────────
# Prevents sentence-transformers from phoning home to huggingface.co on every
# cold start to check for model updates. The model is cached locally after the
# first download; these flags enforce that no network call is made thereafter.
# Required for the local-first / airplane-mode guarantee to hold.
TRANSFORMERS_OFFLINE=1
HF_DATASETS_OFFLINE=1

# ── Admin kill-switch ────────────────────────────────────────────────────────
# Set to false to hard-disable all cloud providers across all workspaces.
# With false, the backend makes zero outbound network calls during normal operation.
ALLOW_CLOUD_PROVIDERS=false

# ── Neo4j (primary graph + vector store) ─────────────────────────────────────
# GraphRAG falls back to SQLite cosine search if Neo4j is unavailable.
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your-neo4j-password
NEO4J_DATABASE=neo4j
