# Backend
SECRET_KEY=change-me-to-a-random-32-char-string
DATABASE_URL=sqlite+aiosqlite:///./data/knowledge.db

# LLM (required for transcript extraction + GraphRAG embeddings)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBED_MODEL=text-embedding-3-small

# Neo4j (primary graph + vector store)
# GraphRAG will fall back to SQLite cosine search if Neo4j is unavailable,
# but Neo4j is strongly recommended for production use.
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your-neo4j-password
NEO4J_DATABASE=neo4j
